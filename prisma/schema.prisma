datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Tenant {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique // e.g., "st-joseph" or "starblue"
  primaryColor  String   @default("#000000")
  secondaryColor String  @default("#ffffff")
  logoUrl       String?
  contactPhone  String?
  contactEmail  String?
  socialLinks   Json?
  pages         Page[]
  createdAt     DateTime @default(now())
}

model Page {
  id        String   @id @default(cuid())
  title     String
  content   Json     // Stores all your promotional sections
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  tenantId  String
}