datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Tenant {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique // e.g., "st-joseph" or "starblue"
  primaryColor  String   @default("#000000")
  secondaryColor String  @default("#ffffff")
  logoUrl       String?
  contactPhone  String?
  contactEmail  String?
  socialLinks   Json?
  pages         Page[]
  leads         Lead[]
  admins        Admin[]
  createdAt     DateTime @default(now())
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  interest  String
  message   String
  date      String?
  time      String?
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  tenantId  String
  createdAt DateTime @default(now())
}

model Page {
  id        String   @id @default(cuid())
  title     String
  content   Json     // Stores all your promotional sections
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  tenantId  String
}

model Admin {
  id           String @id @default(cuid())
  email        String @unique
  passwordHash String
  tenant       Tenant @relation(fields: [tenantId], references: [id])
  tenantId     String
  createdAt    DateTime @default(now())
}